<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/previewBackdrop"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E614201C"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/ivPreviewImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:contentDescription="@string/app_name"
        android:padding="20dp"
        android:scaleType="fitCenter" />

    <ImageButton
        android:id="@+id/btnClosePreview"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_preview_close"
        android:contentDescription="Close preview"
        android:padding="10dp"
        android:src="@drawable/ic_close_white" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_preview_hint"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:text="Tap outside the image to close"
        android:textColor="@android:color/white"
        android:textSize="13sp" />

</FrameLayout>
