<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_primary_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="118dp"
            android:layout_height="118dp"
            android:contentDescription="App Logo"
            android:src="@drawable/ic_logo"
            android:tint="@color/text_inverse" />

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:letterSpacing="0.02"
            android:text="CivicConnect"
            android:textColor="@color/text_inverse"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Thoughtful civic reporting, designed for clarity."
            android:textColor="#D5E7E3"
            android:textSize="15sp" />
    </LinearLayout>
</FrameLayout>
